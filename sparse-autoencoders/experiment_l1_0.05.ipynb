ng base language model: gpt2...\n'}], 'source': 'model, tokenizer= load_base_model()'}, {'cell_type': 'markdown', 'id': 'f3bd3194', 'metadata': {}, 'source': '> ✍️ **My Work** — Loading dataset'}, {'cell_type': 'code', 'execution_count': 103, 'id': 'fb89c213', 'metadata': {'trusted': False}, 'outputs': [{'name': 'stdout', 'output_type': 'stream', 'text': 'Loading dataset: dair-ai/emotion...\n'}], 'source': 'ds = get_text_dataset()'}, {'cell_type': 'markdown', 'id': '629b385b', 'metadata': {}, 'source': '> ✍️ **My Work** — Initializing activations buffer'}, {'cell_type': 'code', 'execution_count': 104, 'id': '3891f285', 'metadata': {'trusted': False}, 'outputs': [], 'source': 'activations = []'}, {'cell_type': 'markdown', 'id': '037cb1dc', 'metadata': {}, 'source': '> ✍️ **My Work** — This my first time using hooks so I want to emphasize it'}, {'cell_type': 'code', 'execution_count': 105, 'id': '7b6a699e', 'metadata': {'trusted': False}, 'outputs': [], 'source': 'def hook(instance, input, output): \n    """\n    hook to register activations of gpt2\n    """\n    activations.append(output)\n'}, {'cell_type': 'markdown', 'id': '12ee9813', 'metadata': {}, 'source': '> ✍️ **My Work** — Device setup'}, {'cell_type': 'code', 'execution_count': 106, 'id': '0668980d', 'metadata': {'trusted': False}, 'outputs': [], 'source': 'device = "cuda" if torch.cuda.is_available() else "mps" if torch.backends.mps.is_available() else "cpu"\nprint(f"Using device: {device}")\nmodel.to(device) \ntarget_module = model.transformer.h[6]\n'}, {'cell_type': 'markdown', 'id': '14067b6b', 'metadata': {}, 'source': '> ✍️ **My Work** — Also first time interacting with feature level interactions'}, {'cell_type': 'code', 'execution_count': 107, 'id': '136784ec', 'metadata': {'trusted': False}, 'outputs': [{'data': {'text/plain': '<torch.utils.hooks.RemovableHandle at 0x155532df0>'}, 'execution_count': 107, 'metadata': {}, 'output_type': 'execute_result'}], 'source': '\ntarget_module.register_forward_h