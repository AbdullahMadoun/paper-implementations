s = np.random.choice(idx_for_lbl, size=max_count, replace=True)\n    for idx in sampled_indices:\n        balanced_activations.append(activations[idx])\n\nprint(f"Original sentences: {len(activations)}")\nprint(f"Balanced sentences (Oversampled): {len(balanced_activations)}")\n\n# Now flatten the BALANCED activations\nall_acts = torch.cat([act[0].squeeze(0) for act in balanced_activations], dim=0) \n\n# Create DataLoader\nbatch_size = 4096  \ndataset = TensorDataset(all_acts)\ndataloader = DataLoader(dataset, batch_size=batch_size, shuffle=True)\nprint(f"Total balanced tokens for training: {len(all_acts)}")\n'}, {'cell_type': 'code', 'execution_count': 44, 'id': '5b022aec', 'metadata': {'trusted': False}, 'outputs': [], 'source': 'sae_model = SAE().to(device)\n\n'}, {'cell_type': 'code', 'execution_count': 45, 'id': '951c30e7', 'metadata': {'trusted': False}, 'outputs': [], 'source': 'optimizer = torch.optim.AdamW(lr = 0.001, params = sae_model.parameters())'}, {'cell_type': 'code', 'execution_count': 87, 'id': '6c064ffb', 'metadata': {'trusted': False}, 'outputs': [{'name': 'stdout', 'output_type': 'stream', 'text': 'Loss: 5.85 | FVE: 0.99 | L0: 5.1\nLoss at epoch 1 is 5.853025436401367\nLoss: 6.00 | FVE: 0.99 | L0: 5.1\nLoss at epoch 1 is 6.001932144165039\nLoss: 6.00 | FVE: 0.99 | L0: 5.1\nLoss at epoch 1 is 5.995000839233398\nLoss: 6.00 | FVE: 0.99 | L0: 5.1\nLoss at epoch 1 is 5.99783182144165\nLoss: 6.06 | FVE: 0.99 | L0: 5.1\nLoss at epoch 1 is 6.062928199768066\nLoss: 6.07 | FVE: 0.99 | L0: 5.1\nLoss at epoch 1 is 6.067967414855957\nLoss: 5.92 | FVE: 0.99 | L0: 5.1\nLoss at epoch 1 is 5.915341377258301\nLoss: 6.05 | FVE: 0.99 | L0: 5.1\nLoss at epoch 1 is 6.053840637207031\nLoss: 6.04 | FVE: 0.99 | L0: 5.1\nLoss at epoch 1 is 6.042441368103027\nLoss: 5.96 | FVE: 0.99 | L0: 5.1\nLoss at epoch 1 is 5.962769508361816\nLoss: 6.01 | FVE: 0.99 | L0: 5.1\nLoss at epoch 1 is 6.007482528686523\nLoss: 6.07 | FVE: 0.99 | L0: 5.1\nLoss at epoch 1 is 6.066722869873047\nL